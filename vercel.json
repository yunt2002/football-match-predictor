{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && npm install --prefix simulator_src",
  "buildCommand": "npm run build --prefix simulator_src",
  "outputDirectory": "simulator_src/dist",
  "framework": null,
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
